# Origin of the Nasara Agro API (the agritrade-backend). Leave EMPTY to fall
# back to this app's own /api/v1 stub route handlers. The admin console's
# auth requires the real backend.
NEXT_PUBLIC_SERVER_URI=http://localhost:4060

# Canonical site origin for metadata/sitemap/OG (falls back to production).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cloudflare Turnstile site key for the public forms. Leave EMPTY to disable
# the widget locally (the backend skips verification without its secret key
# too — set BOTH to enforce in production).
# Test always-pass key: 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
